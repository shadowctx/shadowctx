---
const GITHUB_URL = "https://github.com/shadowctx/shadowctx";
const NPM_INSTALL = "npm install -g shadowctx";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShadowCTX — Your AI's shadow memory</title>
    <meta name="description" content="ShadowCTX captures pages and notes as you browse, then lets any AI assistant query your personal context. Self-hosted, open source, MIT." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:title" content="ShadowCTX — Your AI's shadow memory" />
    <meta property="og:description" content="Browse. Save. Ask. Give your AI the context it's missing." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://shadowctx.com" />
  </head>
  <body class="bg-[#080b0f] text-slate-200 antialiased">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#080b0f]/80 backdrop-blur-md">
      <div class="mx-auto max-w-5xl px-6 flex items-center justify-between h-14">
        <span class="font-mono text-sm font-semibold tracking-tight text-white">shadowctx</span>
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
      </div>
    </nav>

    <main>

      <!-- ── HERO ── -->
      <section class="relative pt-32 pb-24 px-6 overflow-hidden">
        <!-- background glow -->
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
          <div class="h-[600px] w-[600px] rounded-full bg-sky-600/10 blur-[120px]"></div>
        </div>

        <div class="relative mx-auto max-w-3xl text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-sky-500/5 px-4 py-1.5 text-xs font-medium text-sky-400">
            <span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
            Open source · MIT · Self-hosted
          </div>

          <h1 class="mb-5 text-5xl sm:text-6xl font-bold tracking-tight text-white leading-[1.1]">
            Your AI's<br />
            <span class="bg-gradient-to-r from-sky-400 to-blue-500 bg-clip-text text-transparent">shadow memory</span>
          </h1>

          <p class="mb-10 text-lg text-slate-400 max-w-xl mx-auto leading-relaxed">
            ShadowCTX captures the pages you read, the notes you take, and the decisions you make —
            then makes all of it queryable by any AI assistant.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="#install"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-lg bg-sky-500 hover:bg-sky-400 px-6 py-3 text-sm font-semibold text-white transition-colors shadow-lg shadow-sky-500/20"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Install CLI
            </a>
            <a
              href={GITHUB_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              View on GitHub
            </a>
          </div>
        </div>
      </section>

      <!-- ── PROBLEM ── -->
      <section class="py-20 px-6 border-t border-white/5">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-sky-500 mb-4">The Problem</p>
          <h2 class="text-3xl font-bold text-white mb-6">AI agents are context-starved.</h2>
          <div class="space-y-4 text-slate-400 text-lg leading-relaxed">
            <p>They don't know what you were reading an hour ago, what decisions led here, or what that article said.</p>
            <p>You've been copying and pasting context into every chat. That's the wrong approach.</p>
            <p>Your AI should already know — because it was watching.</p>
          </div>
        </div>
      </section>

      <!-- ── HOW IT WORKS ── -->
      <section class="py-20 px-6 border-t border-white/5">
        <div class="mx-auto max-w-4xl">
          <div class="text-center mb-14">
            <p class="text-xs font-semibold uppercase tracking-widest text-sky-500 mb-4">How It Works</p>
            <h2 class="text-3xl font-bold text-white">Three steps. Zero cloud.</h2>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            {[
              {
                step: "01",
                title: "Browse & save",
                description: "The Chrome extension captures any page with one click. Or use the CLI to save URLs from your terminal.",
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>`,
              },
              {
                step: "02",
                title: "Pages are indexed",
                description: "Content is extracted, embedded, and stored locally in SQLite. Your data never leaves your machine.",
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
              },
              {
                step: "03",
                title: "Ask any AI",
                description: "Claude, Cursor, and any MCP-compatible assistant can now search your saved context with a natural query.",
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`,
              },
            ].map((item) => (
              <div class="relative rounded-xl border border-white/8 bg-white/[0.03] p-6 hover:border-sky-500/30 hover:bg-sky-500/5 transition-all">
                <div class="mb-4 flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-500/10 text-sky-400">
                    <Fragment set:html={item.icon} />
                  </div>
                  <span class="font-mono text-xs font-bold text-sky-600">{item.step}</span>
                </div>
                <h3 class="mb-2 font-semibold text-white">{item.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── THREE SURFACES ── -->
      <section class="py-20 px-6 border-t border-white/5">
        <div class="mx-auto max-w-4xl">
          <div class="text-center mb-14">
            <p class="text-xs font-semibold uppercase tracking-widest text-sky-500 mb-4">Three Surfaces</p>
            <h2 class="text-3xl font-bold text-white">Use it however you work.</h2>
          </div>

          <div class="space-y-6">

            <!-- CLI -->
            <div class="rounded-xl border border-white/8 bg-white/[0.03] overflow-hidden">
              <div class="flex items-center gap-3 px-5 py-4 border-b border-white/5">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white text-sm">CLI</p>
                  <p class="text-xs text-slate-500">Terminal-first workflow</p>
                </div>
              </div>
              <pre class="p-5 text-sm leading-relaxed overflow-x-auto"><code><span class="text-slate-500"># Install globally</span>
<span class="text-emerald-400">$</span> <span class="text-white">npm install -g shadowctx</span>

<span class="text-slate-500"># Save a page with tags</span>
<span class="text-emerald-400">$</span> <span class="text-white">ctx save https://arxiv.org/abs/1706.03762 --tag ai --note "attention is all you need"</span>

<span class="text-slate-500"># Semantic search</span>
<span class="text-emerald-400">$</span> <span class="text-white">ctx search "transformer architecture"</span>
<span class="text-sky-400">→</span> <span class="text-slate-300">Attention Is All You Need — arxiv.org  <span class="text-slate-500">2h ago</span></span></code></pre>
            </div>

            <!-- MCP -->
            <div class="rounded-xl border border-white/8 bg-white/[0.03] overflow-hidden">
              <div class="flex items-center gap-3 px-5 py-4 border-b border-white/5">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-violet-500/10 text-violet-400">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white text-sm">MCP Server</p>
                  <p class="text-xs text-slate-500">Claude · Cursor · any MCP client</p>
                </div>
              </div>
              <pre class="p-5 text-sm leading-relaxed overflow-x-auto"><code><span class="text-slate-500">// claude_desktop_config.json</span>
<span class="text-white">{"{"}</span>
  <span class="text-sky-400">"mcpServers"</span><span class="text-white">: {"{"}</span>
    <span class="text-sky-400">"shadowctx"</span><span class="text-white">: {"{"}</span>
      <span class="text-sky-400">"command"</span><span class="text-white">:</span> <span class="text-emerald-400">"npx"</span><span class="text-white">,</span>
      <span class="text-sky-400">"args"</span><span class="text-white">: [</span><span class="text-emerald-400">"-y"</span><span class="text-white">,</span> <span class="text-emerald-400">"@shadowctx/mcp"</span><span class="text-white">],</span>
      <span class="text-sky-400">"env"</span><span class="text-white">: {"{"} </span><span class="text-sky-400">"SHADOWCTX_API_URL"</span><span class="text-white">:</span> <span class="text-emerald-400">"http://localhost:3000"</span> <span class="text-white">{"}"}</span>
    <span class="text-white">{"}"}</span>
  <span class="text-white">{"}"}</span>
<span class="text-white">{"}"}</span></code></pre>
            </div>

            <!-- Extension -->
            <div class="rounded-xl border border-white/8 bg-white/[0.03] overflow-hidden">
              <div class="flex items-center gap-3 px-5 py-4 border-b border-white/5">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 6H18a2.25 2.25 0 012.25 2.25v2.25m-16.5 0V8.25A2.25 2.25 0 015.25 6H9m5.25 0v-.375A2.625 2.625 0 0011.625 3h-.75A2.625 2.625 0 008.25 5.625V6m5.25 0H8.25M3.75 12h16.5m-16.5 4.5h16.5"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white text-sm">Chrome Extension</p>
                  <p class="text-xs text-slate-500">One-click page capture while you browse</p>
                </div>
              </div>
              <div class="p-5">
                <ol class="space-y-2 text-sm text-slate-400">
                  <li class="flex items-start gap-2"><span class="font-mono text-sky-500 text-xs mt-0.5">1.</span> Build: <code class="font-mono text-slate-300 bg-white/5 px-1.5 py-0.5 rounded text-xs">cd packages/extension && pnpm build</code></li>
                  <li class="flex items-start gap-2"><span class="font-mono text-sky-500 text-xs mt-0.5">2.</span> Open <code class="font-mono text-slate-300 bg-white/5 px-1.5 py-0.5 rounded text-xs">chrome://extensions</code> → Load unpacked → select <code class="font-mono text-slate-300 bg-white/5 px-1.5 py-0.5 rounded text-xs">packages/extension/dist</code></li>
                  <li class="flex items-start gap-2"><span class="font-mono text-sky-500 text-xs mt-0.5">3.</span> Click the extension icon on any page to save it to your local ShadowCTX instance.</li>
                </ol>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ── OPEN SOURCE ── -->
      <section class="py-20 px-6 border-t border-white/5 bg-white/[0.015]">
        <div class="mx-auto max-w-4xl">
          <div class="text-center mb-12">
            <p class="text-xs font-semibold uppercase tracking-widest text-sky-500 mb-4">Open Source · Self-hosted</p>
            <h2 class="text-3xl font-bold text-white mb-4">Your data stays yours.</h2>
            <p class="text-slate-400 text-lg max-w-xl mx-auto">MIT license. No accounts. No telemetry. Runs entirely on your machine with Docker or bare Node.</p>
          </div>

          <div class="grid sm:grid-cols-3 gap-4 mb-10">
            {[
              { label: "MIT License", desc: "Use it, fork it, ship it." },
              { label: "SQLite storage", desc: "One file. No database server." },
              { label: "Docker one-liner", desc: "Up in seconds." },
            ].map((f) => (
              <div class="rounded-lg border border-white/8 bg-white/[0.03] p-5 text-center">
                <p class="font-semibold text-white mb-1">{f.label}</p>
                <p class="text-sm text-slate-500">{f.desc}</p>
              </div>
            ))}
          </div>

          <div class="rounded-xl border border-white/8 bg-white/[0.03] overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5">
              <div class="h-3 w-3 rounded-full bg-red-500/60"></div>
              <div class="h-3 w-3 rounded-full bg-yellow-500/60"></div>
              <div class="h-3 w-3 rounded-full bg-green-500/60"></div>
              <span class="ml-2 text-xs text-slate-500 font-mono">terminal</span>
            </div>
            <pre class="p-5 text-sm"><code><span class="text-emerald-400">$</span> <span class="text-white">docker compose up</span>
<span class="text-slate-500 text-xs">
# API available at http://localhost:3000
# Data persisted to ./data/shadowctx.db</span></code></pre>
          </div>
        </div>
      </section>

      <!-- ── INSTALL ── -->
      <section id="install" class="py-24 px-6 border-t border-white/5">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-sky-500 mb-4">Get Started</p>
          <h2 class="text-3xl font-bold text-white mb-8">Ready in one command.</h2>

          <div class="rounded-xl border border-sky-500/20 bg-sky-500/5 p-6 mb-8">
            <div class="flex items-center justify-between gap-4">
              <code class="font-mono text-base text-sky-300">{NPM_INSTALL}</code>
              <button
                id="copy-btn"
                onclick={`navigator.clipboard.writeText('${NPM_INSTALL}').then(() => { const b = document.getElementById('copy-btn'); b.textContent = 'Copied!'; setTimeout(() => b.textContent = 'Copy', 2000); })`}
                class="shrink-0 rounded-md border border-sky-500/30 bg-sky-500/10 px-3 py-1.5 text-xs font-medium text-sky-400 hover:bg-sky-500/20 transition-colors cursor-pointer"
              >
                Copy
              </button>
            </div>
          </div>

          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            View full docs on GitHub
          </a>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 py-8 px-6">
      <div class="mx-auto max-w-5xl flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-mono text-sm text-slate-600">shadowctx</span>
        <div class="flex items-center gap-5 text-sm text-slate-600">
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="hover:text-slate-400 transition-colors">GitHub</a>
          <span>MIT License</span>
        </div>
      </div>
    </footer>

  </body>
</html>
